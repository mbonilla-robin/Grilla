# Supabase — proyecto DEDICADO de Grilla (no mezclar con Robin u otras apps)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto-grilla.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Solo servidor — para agregar miembros al equipo por correo
# Supabase Dashboard → Settings → API Keys → Secret key (sb_secret_...)
# O en la pestaña "Legacy API Keys" → service_role
SUPABASE_SECRET_KEY=tu-clave-secreta
# SUPABASE_SERVICE_ROLE_KEY=tambien-funciona-si-usas-la-legacy

# Solo para migraciones (npm run db:push) — no se usa en la app
# Dashboard → Connect → Session pooler (IPv4) — NO uses db.[ref].supabase.co (solo IPv6)
# Si la contraseña tiene $, @, #, etc., codifícala en la URL ($ → %24, @ → %40)
DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres

# Gemini — briefs con IA (https://aistudio.google.com/apikey)
# Las claves nuevas empiezan con AQ. (también funciona GOOGLE_API_KEY)
GEMINI_API_KEY=AQ...
# GEMINI_MODEL=gemini-2.5-flash
